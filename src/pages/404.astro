---
import BaseLayout from "~/layouts/BaseLayout.astro";

const code = 404;
const hex = String(code);
---

<BaseLayout title="404 · 走丢了" description="找不到这一页。">
  <section class="nf">
    <div class="nf__inner">
      <p class="t-kicker nf__kicker">Error</p>
      <h1 class="nf__code">{hex}</h1>
      <p class="nf__title">走丢了。</p>
      <p class="nf__body">
        这一页不在书架上。<br />
        可能地址错了，可能它还没被写出来。
      </p>
      <ul class="nf__links">
        <li><a href="/">回首页</a></li>
        <li><a href="/works">看作品</a></li>
        <li><a href="/contact">联系我</a></li>
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .nf {
    min-height: 70vh;
    display: grid;
    place-items: center;
    padding: var(--spacing-24) var(--spacing-8);
  }
  .nf__inner {
    text-align: center;
    max-width: 36rem;
  }
  .nf__kicker {
    color: var(--color-cinnabar);
    margin-bottom: var(--spacing-6);
  }
  .nf__code {
    font-family: var(--font-mono);
    font-size: clamp(8rem, 5rem + 15vw, 18rem);
    line-height: 0.85;
    letter-spacing: -0.05em;
    font-weight: 500;
    color: var(--color-ink);
    margin: 0 0 var(--spacing-6);
  }
  .nf__title {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 500;
    line-height: 1.1;
    margin: 0 0 var(--spacing-6);
    font-variation-settings: "opsz" 60, "SOFT" 30;
  }
  .nf__body {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    line-height: 1.55;
    color: var(--color-mute);
    margin: 0 0 var(--spacing-8);
  }
  .nf__links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    justify-content: center;
    gap: var(--spacing-6);
  }
  .nf__links a {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-ink);
    text-decoration: none;
    padding: 0.5em 0;
    border-bottom: 1px solid transparent;
    transition: border-color var(--duration-base) var(--ease-out-soft);
  }
  .nf__links a:hover {
    border-bottom-color: var(--color-ink);
  }
</style>
