---
interface Props {
  label: string;
  num?: string;
  align?: "left" | "center";
}

const { label, num, align = "left" } = Astro.props;
---

<div class="sl" data-align={align}>
  <span class="sl__line" aria-hidden="true"></span>
  <span class="sl__inner">
    {num && <span class="t-num sl__num">{num}</span>}
    <span class="t-kicker sl__label">{label}</span>
  </span>
  <span class="sl__line" aria-hidden="true"></span>
</div>

<style>
  .sl {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: var(--spacing-4);
    margin: var(--spacing-16) 0 var(--spacing-8);
  }

  .sl__line {
    height: 1px;
    background-color: var(--color-rule);
  }

  .sl__inner {
    display: inline-flex;
    align-items: baseline;
    gap: var(--spacing-3);
  }

  .sl__num {
    font-size: var(--text-xs);
    color: var(--color-mute);
    letter-spacing: 0.05em;
  }

  .sl__label {
    color: var(--color-ink);
    font-weight: 600;
  }
</style>
